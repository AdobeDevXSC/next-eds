{
  "name": "@adobe/aem-block-collection",
  "private": true,
  "version": "1.0.0",
  "description": "Block collection for AEM, rendered via Next.js (RSC) — see DEPLOYMENT.md",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:cf:preview": "opennextjs-cloudflare build && wrangler deploy --env preview",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"blocks/**/*.css\" \"styles/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:fix": "npm run lint:js -- --fix && npm run lint:css -- --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/aem-block-collection.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/adobe/aem-block-collection/issues"
  },
  "homepage": "https://github.com/adobe/aem-block-collection#readme",
  "dependencies": {
    "next": "^16.2.9",
    "node-html-parser": "7.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.29.7",
    "@opennextjs/cloudflare": "^1.20.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "wrangler": "^4.105.0"
  }
}
